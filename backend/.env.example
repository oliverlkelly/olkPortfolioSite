# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio

# ─── Server ─────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Admin auth ─────────────────────────────────────────
# Change BOTH of these before deploying!
ADMIN_PASSWORD=portfolio-admin
ADMIN_SECRET=super-secret-signing-key-change-me

# ─── Email (optional — for /api/contact) ────────────────
