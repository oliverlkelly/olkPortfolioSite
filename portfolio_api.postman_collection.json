              "raw": "{{baseUrl}}/api/experience/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "experience", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "b5e8b4e4-...",
                  "description": "Experience UUID"
                }
              ]
            }
          }
        },
        {
          "name": "Get Education",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/education",
              "host": ["{{baseUrl}}"],
              "path": ["api", "education"]
