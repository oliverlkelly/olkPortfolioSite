{
  "info": {
    "name": "Portfolio API",
    "description": "API collection for Portfolio website backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "profile"]
            }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"]
            }
          }
        },
        {
          "name": "Get Featured Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/featured",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "featured"]
            }
          }
        },
        {
          "name": "Get Single Project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "b5e8b4e4-...",
                  "description": "Project UUID"
                }
              ]
            }
          }
        },
        {
          "name": "Get Experience",
